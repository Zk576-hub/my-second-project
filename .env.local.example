# Copy this file to .env.local for local development.
# On Vercel: paste each key into Project > Settings > Environment Variables.

# --- FRED (Federal Reserve Economic Data) ---
# Free. Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# --- GNews (News headlines, free tier works in production) ---
# Free tier: 100 requests/day. Register at: https://gnews.io/
GNEWS_API_KEY=your_gnews_api_key_here

# --- CoinGecko ---
# No key required. Free public API is used automatically.

# --- CFTC COT data ---
# No key required. Public Socrata dataset. Fetched weekly by the app.
# If CFTC changes the dataset ID, update this (check publicreporting.cftc.gov):
CFTC_DATASET_ID=6dca-aqww
